# Environment
NODE_ENV=production

# Server Configuration
PORT=10000
# Comma-separated list of allowed origins (Vercel production + preview)
CORS_ORIGINS=https://your-app.vercel.app,https://your-app-git-branch-user.vercel.app
# Fallback single origin
FRONTEND_URL=https://your-app.vercel.app

# Uploads Directory (Render Disk mount path)
UPLOADS_DIR=/uploads

# Database - MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/banana-ranch?retryWrites=true&w=majority

# JWT and Session
JWT_SECRET=change-me-strong-random-hex
JWT_EXPIRES_IN=7d
SESSION_SECRET=change-me-strong-random-hex

# Email Configuration (optional)
EMAIL_FROM=info@bananaaquapark.com
EMAIL_HOST=smtp.office365.com
EMAIL_PORT=587
EMAIL_USER=info@bananaaquapark.com
EMAIL_PASS=your-app-password
EMAIL_SECURE=false

# Cloudinary (optional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Stripe (optional)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Microsoft Graph (optional)
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_SENDER_UPN=# Environment
NODE_ENV=development

# Server Configuration
PORT=5000
FRONTEND_URL=http://localhost:3000

# Uploads Directory (local development)
UPLOADS_DIR=./uploads

# Database
MONGODB_URI=mongodb://localhost:27017/banana-ranch

# JWT Secret (change this in production)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Email Configuration (for contact forms and notifications)
EMAIL_FROM=noreply@bananaranch.com
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Cloudinary (for image uploads - optional)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Stripe (for payments - optional)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
